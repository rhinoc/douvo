{
  "name": "vocabulary-and-prompt-check",
  "model": "quality",
  "runs": 10,
  "punctuationStyle": "spaces",
  "softenEmotionalLanguage": false,
  "outputStyle": "original",
  "outputStyleStrength": "medium",
  "reasoningMode": "disabled",
  "systemPromptFile": "system-prompt.txt",
  "userPromptFile": "user-message.txt",
  "vocabulary": [
    "textarea",
    "README",
    "placeholder",
    "Codex",
    "scroll",
    "优化",
    "会话"
  ],
  "inputs": [
    {
      "id": "placeholder-space-case",
      "text": "place HOLDER",
      "expected": "placeholder",
      "mustContain": "placeholder",
      "mustNotContain": "place HOLDER",
      "shouldChange": true,
      "allowFallback": true
    },
    {
      "id": "placeholder-snake-case",
      "text": "place_holder",
      "expected": "placeholder",
      "mustContain": "placeholder",
      "mustNotContain": "place_holder",
      "shouldChange": true
    },
    {
      "id": "textarea-split",
      "text": "text area 里面 place holder 好像有问题",
      "expected": "textarea 里面 placeholder 好像有问题",
      "mustContain": [
        "textarea",
        "placeholder"
      ],
      "mustNotContain": [
        "text area",
        "place holder"
      ],
      "shouldChange": true
    },
    {
      "id": "meeting-time-correction",
      "text": "会议先放到下午三点哦不四点",
      "mustContain": "下午四点",
      "mustNotContain": [
        "下午三点",
        "哦不"
      ],
      "shouldChange": true
    },
    {
      "id": "quantity-number-correction",
      "text": "这份商品库存还有六份",
      "expected": "这份商品库存还有 6 份",
      "mustContain": "6 份",
      "mustNotContain": "六份",
      "shouldChange": true
    },
    {
      "id": "readme-dot-md-correction",
      "text": "帮我更新下 readmi 点 MD",
      "expected": "帮我更新下 README.md",
      "mustContain": "README.md",
      "mustNotContain": [
        "readmi",
        "点 MD"
      ],
      "shouldChange": true
    }
  ]
}
